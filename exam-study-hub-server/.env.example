# 复制本文件为 .env 并填入真实值（.env 不会提交到 git）
# 数据库连接串：postgresql+psycopg://用户名:密码@主机:端口/数据库名
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/exam_study

# 允许跨域访问的前端地址，多个用逗号分隔
CORS_ORIGINS=http://localhost:5173

# JWT 签名密钥：生产环境务必改成随机长串（如 `openssl rand -hex 32` 生成）
SECRET_KEY=change-me-to-a-random-long-string
